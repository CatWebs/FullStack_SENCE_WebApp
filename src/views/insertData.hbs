<header class="page-header">
  <div class="container">
    <h1>Dashboard interno</h1>
    <p>Formularios para crear usuario y para crear producto en base de datos.</p>
  </div>
</header>
<section class="pb-5">
  <div class="container">
    <div class="row g-4 align-items-start">

      <!-- ── CREATE ACCOUNT ── -->
      <div class="col-12 col-lg-5">
        <div class="form-card">

          <div class="card-heading">
            <span class="card-icon icon-account">👤</span>
            Crear cuenta
          </div>

          <div class="row g-3">
            <div class="col-6">
              <label class="form-label">Nombre</label>
              <input type="text" class="form-control" placeholder="Jane" />
            </div>
            <div class="col-6">
              <label class="form-label">Apellido</label>
              <input type="text" class="form-control" placeholder="Doe" />
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label">Email</label>
            <input
              type="email"
              class="form-control"
              placeholder="jane@example.com"
            />
          </div>

          <div class="mt-3">
            <label class="form-label">Contraseña</label>
            <input
              type="password"
              class="form-control"
              placeholder="••••••••"
            />
          </div>

          <button class="btn-register mt-4">Registrar</button>

        </div>
      </div>

      <!-- ── ADD PRODUCTS ── -->
      <div class="col-12 col-lg-7">
        <div class="form-card">

          <div class="card-heading">
            <span class="card-icon icon-product">🗂️</span>
            Agregar productos
          </div>

          <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input
              type="text"
              class="form-control"
              placeholder="Hand-dyed Merino Wool"
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Descripción</label>
            <textarea
              class="form-control"
              rows="3"
              placeholder="Soft, sustainable, and vibrant..."
            ></textarea>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label">Stock</label>
              <input type="number" class="form-control" placeholder="45" />
            </div>
            <div class="col-6">
              <label class="form-label">Precio ($)</label>
              <input type="number" class="form-control" placeholder="24.99" />
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Categoría</label>
            <select class="form-control">
              <option value="" disabled selected>Selecciona una categoría</option>
              <option value="acrilico">Acrílico</option>
              <option value="algodon">Algodón</option>
              <option value="lana">Lana</option>
              <option value="poliester">Poliéster</option>
            </select>
          </div>

          <div class="mb-1">
            <label class="form-label">Imagen URL</label>
            <div class="input-group input-group-img">
              <input
                type="url"
                class="form-control"
                placeholder="https://image-placeholder.com/yarn"
              />
              <span class="input-icon">🖼</span>
            </div>
          </div>

          <button class="btn-add mt-4">
            <span style="font-size:1.1rem;">＋</span>
            Registrar producto
          </button>

        </div>
      </div>

    </div>
  </div>
</section>