<!-- Header -->
<nav class="navbar navbar-expand-lg sticky-top px-3 px-lg-5">
  <a class="navbar-brand" href="/">Arañitas Lanas y Ovillos</a>
  <button
    class="navbar-toggler border-0"
    type="button"
    data-bs-toggle="collapse"
    data-bs-target="#navMenu"
  >
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse justify-content-center" id="navMenu">
    <ul class="navbar-nav gap-3">
      <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
      <li class="nav-item"><a
          class="nav-link active"
          href="/catalogo"
        >Tienda</a></li>
      <li class="nav-item"><a class="nav-link" href="/crear">Insertar datos</a></li>
    </ul>
  </div>
  <div class="d-flex align-items-center gap-3 ms-auto">
    <a
      href="#"
      class="cart-badge text-dark position-relative"
      style="font-size:1.2rem;"
    >
      🛒<span class="badge rounded-pill">0</span>
    </a>
    <a href="" class="btn btn-login">Iniciar Sesión</a>
  </div>
</nav>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-1">
      <div>
        <h2 class="section-title mb-0">Ovillos disponibles</h2>
        <p class="section-sub mb-0">No te quedes sin tu ovillo favorito</p>
      </div>
    </div>

    <div class="container py-4">
      <h1 class="mb-4">{{title}}</h1>

      <div class="row row-cols-1 row-cols-md-3 g-4">
        {{#each productos}}
          <div class="col">
            <div class="card h-100 shadow-sm">

              <!-- Ruta de imagen con el helper -->
              <img
                src="{{imgPath this.nombre this.categoria.nombre}}"
                class="card-img-top card-img-catalogo"
                alt="{{this.nombre}}"
                onerror="this.replaceWith('🧵')"
              />

              <div class="card-body d-flex flex-column">
                <!-- Badge de categoría -->
                <span
                  class="badge badge-nuevo badge-pill"
                >{{this.categoria.nombre}}</span>

                <h5 class="card-title mt-2">{{this.nombre}}</h5>
                <p class="card-text text-muted small">{{this.descripcion}}</p>

                <div class="mt-auto">
                  <p class="fw-bold fs-5 mb-2">${{this.precio}}</p>
                  <div
                    class="d-flex justify-content-between align-items-center"
                  >
                    <span class="text-muted small">Stock: {{this.stock}}</span>
                    <a href="/producto/{{this.id}}" class="btn btn-add btn-sm">
                      Agregar al carro
                    </a>
                  </div>
                </div>

              </div>
            </div>
          </div>
        {{else}}
          <div class="empty-state">
            <h3>No hay productos disponibles.</h3>
            <p>¡Anímate a ser el primero en crear uno!</p>
          </div>
        {{/each}}
      </div>
    </div>
  </div>
</section>

