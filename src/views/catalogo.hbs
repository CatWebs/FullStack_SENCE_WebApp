<!-- Header -->
<nav class="navbar navbar-expand-lg sticky-top px-3 px-lg-5">
  <a class="navbar-brand" href="/">Arañitas Lanas y Ovillos</a>
  <button
    class="navbar-toggler border-0"
    type="button"
    data-bs-toggle="collapse"
    data-bs-target="#navMenu"
  >
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse justify-content-center" id="navMenu">
    <ul class="navbar-nav gap-3">
      <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
      <li class="nav-item"><a
          class="nav-link active"
          href="/catalogo"
        >Tienda</a></li>
      <li class="nav-item"><a class="nav-link" href="/crear">Insertar datos</a></li>
    </ul>
  </div>
  <div class="d-flex align-items-center gap-3 ms-auto">
    <a
      href="#"
      class="cart-badge text-dark position-relative"
      style="font-size:1.2rem;"
    >
      🛒<span class="badge rounded-pill">0</span>
    </a>
    <a href="" class="btn btn-login">Iniciar Sesión</a>
  </div>
</nav>
<section class="py-5">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-1">
      <div>
        <h2 class="section-title mb-0">Ovillos disponibles</h2>
        <p class="section-sub mb-0">No te quedes sin tu ovillo favorito</p>
      </div>
    </div>

    <div class="row g-3 mt-2">
      {{#each productos}}
        <div class="col-6 col-lg-3">
          <div class="product-card card h-100" id="product-{{this.id}}">
            <div class="product-img-wrap">
              <div class="hilo-icon">🧵</div>
            </div>
            <div class="product-body">
              <p class="product-name mb-0">{{this.nombre}}</p>
              <p class="product-type mb-3">{{this.categoria.nombre}}</p>
              <span class="product-price">${{this.precio}}</span>
              <p
                class="text-muted"
                style="font-size: 10.5px;"
              >{{this.descripcion}}</p>

              <div class="d-flex justify-content-end gap-2 mt-2">
                <a
                  href="/editar/{{this.id}}"
                  class="btn-mini btn-edit btn-cart"
                >✏️</a>

                <form
                  action="/eliminar/{{this.id}}"
                  method="POST"
                  style="display:inline;"
                >
                  <button type="submit" class="btn-mini btn-cart">🗑️</button>
                </form>
              </div>
              <div class="text-center mt-2"><div
                  class="d-flex justify-content-between align-items-center"
                >

                  <button type="button" class="btn-register">🛒 Añadir al
                    carrito</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      {{else}}
        <div class="empty-state">
          <h3>No hay productos disponibles.</h3>
          <p>¡Anímate a ser el primero en crear uno!</p>
        </div>
      {{/each}}
    </div>
  </div>
</section>

